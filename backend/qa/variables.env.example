# QA environment variables — copy this file to variables.env and fill in values.
# variables.env is gitignored; this example file is checked in as documentation.
#
# Setup steps:
#   1. Copy: cp backend/qa/variables.env.example backend/qa/variables.env
#   2. Fill in all values below.
#   3. Create a QA test user in Supabase (one-time):
#      Dashboard → Authentication → Users → Add user
#      Set email + password. The app UI uses OTP but Supabase supports
#      email+password for the same project simultaneously.
#
# QA_BASE_URL: Railway develop backend URL (no trailing slash).
# SUPABASE_URL: Your Supabase project URL — Dashboard → Project Settings → Data API → Project URL
# SUPABASE_PUBLISHABLE_KEY: The publishable key — Dashboard → Project Settings → API → Publishable (anon) key
# QA_TEST_EMAIL: Email for the dedicated QA test user (must have a password set in Supabase)
# QA_TEST_PASSWORD: Password for the QA test user

QA_BASE_URL=https://your-railway-develop-url.railway.app
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here
QA_TEST_EMAIL=qa-test@yourdomain.com
QA_TEST_PASSWORD=your-qa-test-password
