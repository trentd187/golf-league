# pnpm config for the mobile app.
#
# node-linker=hoisted produces a flat, npm-style node_modules instead of pnpm's
# default symlinked layout. Expo/React Native native tooling assumes binaries and
# packages live at conventional top-level paths; the symlinked layout broke the
# EAS release build's Sentry source-map upload — Gradle could not start
# node_modules/@sentry/cli/bin/sentry-cli because the platform binary sat behind a
# .pnpm symlink. Hoisting places @sentry/cli (and its downloaded binary) at the
# path the SentryUpload task invokes. This is Expo's recommended setting for pnpm.
node-linker=hoisted
