# mobile/.env.example
# Copy to mobile/.env (gitignored) and fill in. EXPO_PUBLIC_* vars are inlined into
# the JS bundle at build time. See mobile/docs/observability.md for the Sentry setup.

# --- API + Supabase ---
EXPO_PUBLIC_API_URL=https://golf-league-develop.up.railway.app
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<supabase-publishable-key>

# --- Sentry (runtime) ---
# Leave EXPO_PUBLIC_SENTRY_DSN unset to disable Sentry entirely (local dev / CI):
# the app runs identically and sends no events.
EXPO_PUBLIC_SENTRY_DSN=
# development | preview | production — falls back to __DEV__ when unset.
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development

# --- Sentry (build-time only — set via EAS Secrets, do NOT put real values here) ---
# Used by the @sentry/react-native config plugin for source-map upload during EAS builds.
#   SENTRY_ORG=<org-slug>
#   SENTRY_PROJECT=<project-slug>
#   SENTRY_AUTH_TOKEN=<token>   # EAS Secret only — never commit
