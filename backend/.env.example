PORT=8080
DATABASE_URL=postgres://postgres:changeme@db:5432/golf_league?sslmode=disable
CLERK_SECRET_KEY=
# CLERK_JWKS_URL: Find this in the Clerk Dashboard → API Keys → Advanced.
# Format: https://<your-clerk-domain>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=
ENV=development
# GOLF_COURSE_API_KEY: Free API key from https://golfcourseapi.com (sign-up required).
# Enables the /courses/search-external and /courses/import-external endpoints.
# Leave empty to disable external course import (manual course entry still works).
GOLF_COURSE_API_KEY=

# ── Observability (Grafana Cloud) ───────────────────────────────────────────
# LOG_LEVEL: Minimum log level shipped to Loki and printed to stdout.
# Valid values: debug | info | warn | error  (default: info)
LOG_LEVEL=info

# Loki — structured log push. All three must be set to enable; empty = stdout only.
# LOKI_URL: Base URL only — code appends /loki/api/v1/push automatically.
# Find in Grafana Cloud → Connections → Data sources → Loki → Details (e.g. https://logs-prod-xxx.grafana.net)
LOKI_URL=
LOKI_USER=
LOKI_API_KEY=

# OTLP gateway — receives both metrics (→ Mimir) and traces (→ Tempo) via the same endpoint.
# Find in Grafana Cloud → My Account → OTLP endpoint details.
OTLP_ENDPOINT=
OTLP_USER=
OTLP_API_KEY=

# Pyroscope — continuous CPU and memory profiling.
# Find in Grafana Cloud → Connections → Data sources → Profiles → Details.
PYROSCOPE_URL=
PYROSCOPE_USER=
PYROSCOPE_API_KEY=
